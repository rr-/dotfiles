#!/usr/bin/env -S uv run --script
#
# /// script
# requires-python = ">=3.12"
# dependencies = ["tqdm"]
# ///
#
# Uploads files to my dedibox via SSH and outputs copyable links

import io
import shlex
import subprocess
import sys
import tarfile
import urllib.parse
from collections.abc import Callable, Iterable
from dataclasses import dataclass
from pathlib import Path, PurePosixPath
from typing import BinaryIO

from tqdm import tqdm

BASE_DIR = "/home/dash/srv/files/data/pub/"
BASE_URL = "https://files.bad.pink/serve/pub/"
REMOTE_HOST = "bad.pink"


@dataclass(frozen=True)
class UploadItem:
    src_path: Path
    target_name: PurePosixPath
    is_dir: bool = False


class ProgressReader(io.RawIOBase):
    def __init__(
        self,
        handle: BinaryIO,
        on_progress: Callable[[int], object],
    ) -> None:
        self.handle = handle
        self.on_progress = on_progress

    def readable(self) -> bool:
        return True

    def read(self, size: int = -1) -> bytes:
        chunk = self.handle.read(size)
        self.on_progress(len(chunk))
        return chunk


def warn(message: str) -> None:
    print(message, file=sys.stderr)


def collect_single_file(path: Path) -> UploadItem:
    return UploadItem(path, PurePosixPath(path.name))


def collect_dir(top: Path) -> Iterable[UploadItem]:
    yield UploadItem(top, PurePosixPath(top.name), is_dir=True)
    for path in top.rglob("*"):
        if path.is_symlink():
            warn(f"Skipping symlink: {path}")
            continue
        target_name = PurePosixPath(top.name) / path.relative_to(top)
        if path.is_dir():
            yield UploadItem(path, target_name, is_dir=True)
        elif path.is_file():
            yield UploadItem(path, target_name)


def collect_files(args: list[str]) -> Iterable[UploadItem]:
    for arg in args:
        path = Path(arg)
        if not path.exists():
            warn(f"File does not exist: {path}")
            continue
        if path.is_symlink():
            warn(f"Skipping symlink: {path}")
            continue
        if path.is_file():
            yield collect_single_file(path)
        elif path.is_dir():
            yield from collect_dir(path)


def build_remote_path(target_name: PurePosixPath) -> str:
    return BASE_DIR + str(target_name)


def build_url(target_name: PurePosixPath) -> str:
    return BASE_URL + urllib.parse.quote(str(target_name), safe="/")


def add_to_tar(
    tar: tarfile.TarFile,
    item: UploadItem,
    progress: tqdm,
) -> None:
    tar_info = tar.gettarinfo(item.src_path, arcname=str(item.target_name))
    if item.is_dir:
        tar.addfile(tar_info)
        return

    with item.src_path.open("rb") as handle:
        reader = ProgressReader(handle, progress.update)
        tar.addfile(tar_info, reader)


def send(items: list[UploadItem]) -> None:
    if not items:
        print("Nothing to send.", file=sys.stderr)
        return

    files = [item for item in items if not item.is_dir]
    urls = [build_url(item.target_name) for item in files]
    commands: list[str] = []
    total_bytes = sum(item.src_path.stat().st_size for item in files)

    dirs = {build_remote_path(item.target_name) for item in items if item.is_dir}
    dirs.update(
        str(PurePosixPath(build_remote_path(item.target_name)).parent)
        for item in files
    )

    sorted_dirs = sorted(dirs)
    for dir_name in sorted_dirs:
        commands.append("mkdir -p %s" % shlex.quote(dir_name))

    commands.append("tar x -C %s" % shlex.quote(BASE_DIR))

    for dir_name in sorted_dirs:
        commands.append("chmod 0755 %s" % shlex.quote(dir_name))

    for item in files:
        dst_path = build_remote_path(item.target_name)
        commands.append("chmod 0644 %s" % shlex.quote(dst_path))

    cmdline = ["ssh", REMOTE_HOST, " && ".join(commands)]

    proc = subprocess.Popen(
        cmdline,
        stdin=subprocess.PIPE,
        stdout=subprocess.DEVNULL,
    )
    assert proc.stdin is not None
    upload_error: str | None = None
    with tqdm(
        total=total_bytes,
        unit="B",
        unit_scale=True,
        unit_divisor=1024,
        dynamic_ncols=True,
        desc="Uploading",
    ) as progress:
        try:
            with tarfile.open(mode="w|", fileobj=proc.stdin) as tar:
                for index, item in enumerate(files, 1):
                    progress.set_postfix(
                        file=str(item.src_path),
                        files=f"{index}/{len(files)}",
                        refresh=True,
                    )
                    add_to_tar(tar, item, progress)
                for item in items:
                    if item.is_dir:
                        add_to_tar(tar, item, progress)
            proc.stdin.close()
        except BrokenPipeError:
            proc.wait()
            upload_error = "Upload failed: remote command closed the connection."
    if upload_error is not None:
        print(upload_error, file=sys.stderr)
        sys.exit(1)
    proc.wait()
    if proc.returncode != 0:
        print(
            f"Upload failed: ssh exited with status {proc.returncode}.",
            file=sys.stderr,
        )
        sys.exit(1)
    for url in urls:
        print(url)


def main() -> None:
    send(list(collect_files(sys.argv[1:])))


if __name__ == "__main__":
    main()
