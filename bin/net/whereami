from typing import cast

import requests


def get_ipv4() -> str:
    response = requests.get("https://api.ipify.org?format=json")
    response.raise_for_status()
    return cast(str, response.json()["ip"])


def main() -> None:
    print(get_ipv4())


if __name__ == "__main__":
    main()
