#!/usr/bin/env python3
import argparse
import json
import re
import subprocess
from dataclasses import dataclass
from pathlib import Path
from typing import Literal

_ts_re = re.compile(r"^(?:(\d+):)?(\d{1,2}):(\d{1,2})(?:\.(\d+))?$")


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser()
    p.add_argument("input", type=Path)
    p.add_argument("-o", "--output", type=Path)
    p.add_argument("--no-audio", action="store_true")
    p.add_argument(
        "--quality", default="2M", help="Target video bitrate, e.g. 2M"
    )
    p.add_argument("--height", type=int, default=720, help="Target height")
    p.add_argument("--from", dest="start", help="Start time or frame #")
    p.add_argument("--to", dest="end", help="End time or frame #")
    p.add_argument("--preset", default="fast", help="Preset (video only)")
    p.add_argument("--gif", action="store_true", help="Output .gif, not .mp4")
    p.add_argument(
        "--crop",
        help="Center-crop to width,height percent (e.g. 0.5 or 50%% or 0.5,0.7)",
    )
    args = p.parse_args()
    if args.gif:
        args.no_audio = True
    return args


def is_timestamp(v: str) -> bool:
    return ":" in v


def parse_timestamp_seconds(v: str) -> float:
    m = _ts_re.match(v.strip())
    if not m:
        raise ValueError(f"Invalid timestamp: {v!r}")
    h_s, m_s, s_s, frac_s = m.groups()
    hours = int(h_s) if h_s else 0
    minutes = int(m_s)
    seconds = int(s_s)
    frac = float(f"0.{frac_s}") if frac_s else 0.0
    return hours * 3600 + minutes * 60 + seconds + frac


def _parse_percent(raw: str) -> float:
    value = float(raw.strip().rstrip("%"))
    if not (0.0 <= value <= 1.0):
        raise ValueError("crop value must be within 0..1")
    return value


def parse_crop_percent(
    v: str,
) -> tuple[float, float, float | None, float | None]:
    raw = v.strip()
    if not raw:
        raise ValueError("crop value is empty")

    if "+" in raw:
        size_raw, offset_raw = (part.strip() for part in raw.split("+", 1))
    else:
        size_raw, offset_raw = raw, None

    size_parts = re.split(r"[x,]", size_raw)
    if not 1 <= len(size_parts) <= 2:
        raise ValueError(f"Invalid crop size: {v!r}")
    if len(size_parts) == 1:
        size_parts = [size_parts[0], size_parts[0]]

    w = _parse_percent(size_parts[0])
    h = _parse_percent(size_parts[1])

    if offset_raw is None:
        return w, h, None, None

    offset_parts = re.split(r"[x,]", offset_raw)
    if not 1 <= len(offset_parts) <= 2:
        raise ValueError(f"Invalid crop offset: {v!r}")
    if len(offset_parts) == 1:
        offset_parts = [offset_parts[0], offset_parts[0]]

    x_offset = _parse_percent(offset_parts[0])
    y_offset = _parse_percent(offset_parts[1])
    return w, h, x_offset, y_offset


def crop_filter_from_args(args: argparse.Namespace) -> str | None:
    if not args.crop:
        return None
    w, h, x_offset, y_offset = parse_crop_percent(args.crop)
    x_offset = (
        (1.0 - w) * x_offset if x_offset is not None else (1.0 - w) / 2.0
    )
    y_offset = (
        (1.0 - h) * y_offset if y_offset is not None else (1.0 - h) / 2.0
    )
    return (
        f"crop=iw*{w:.6f}:ih*{h:.6f}" f":iw*{x_offset:.6f}:ih*{y_offset:.6f}"
    )


def build_video_filter(height: int, crop_filter: str | None) -> str:
    parts: list[str] = []
    if crop_filter:
        parts.append(crop_filter)
    parts.append(f"scale=-2:{height}")
    return ",".join(parts)


@dataclass(frozen=True, slots=True)
class TrimWindow:
    mode: Literal["none", "timestamps", "frames"]
    start: float
    end: float | None

    @classmethod
    def mode_from_args(
        cls, args: argparse.Namespace
    ) -> Literal["none", "timestamps", "frames"]:
        start_raw = args.start
        end_raw = args.end
        if not start_raw and not end_raw:
            return "none"

        start_ts = bool(start_raw and is_timestamp(start_raw))
        end_ts = bool(end_raw and is_timestamp(end_raw))
        frame_mode = any(
            not is_timestamp(v) for v in (start_raw, end_raw) if v
        )

        if frame_mode and (start_ts or end_ts):
            raise SystemExit("Pick timestamps OR frames, sis, not both.")

        return "frames" if frame_mode else "timestamps"

    @classmethod
    def from_args(
        cls, args: argparse.Namespace, *, fps: float | None = None
    ) -> "TrimWindow":
        start_raw = args.start
        end_raw = args.end
        if not start_raw and not end_raw:
            return cls(mode="none", start=0.0, end=None)

        mode = cls.mode_from_args(args)
        if mode == "frames":
            assert fps is not None
            return cls(
                mode="frames",
                start=float(start_raw) if start_raw else 0.0,
                end=float(end_raw) if end_raw else None,
            )
        else:
            return cls(
                mode="timestamps",
                start=parse_timestamp_seconds(start_raw) if start_raw else 0.0,
                end=parse_timestamp_seconds(end_raw) if end_raw else None,
            )

    def ffmpeg_timestamp_flags(self) -> list[str]:
        if self.mode not in ("timestamps",):
            return []
        flags: list[str] = []
        if self.start:
            flags += ["-ss", str(self.start)]
        if self.end is not None:
            flags += ["-to", str(self.end)]
        return flags

    def frame_range(self) -> tuple[int, int | None]:
        assert self.mode == "frames"
        start_i = int(self.start)
        if start_i != self.start:
            raise ValueError("frame start must be an integer")
        end_i = None if self.end is None else int(self.end)
        if end_i is not None and end_i != self.end:
            raise ValueError("frame end must be an integer")
        return start_i, end_i

    def seconds_range(self, *, fps: float) -> tuple[float, float | None]:
        if self.mode == "frames":
            start_i, end_i = self.frame_range()
            start_s = start_i / fps
            end_s = (end_i + 1) / fps if end_i is not None else None
            return start_s, end_s
        return self.start, self.end


def probe_fps(path: Path) -> float:
    cmd = [
        "ffprobe",
        "-v",
        "error",
        "-select_streams",
        "v:0",
        "-show_entries",
        "stream=avg_frame_rate,r_frame_rate",
        "-of",
        "json",
        str(path),
    ]
    out = subprocess.check_output(cmd, text=True)
    data = json.loads(out)
    r = data["streams"][0].get("avg_frame_rate") or data["streams"][0].get(
        "r_frame_rate"
    )
    if not r or r == "0/0":
        raise RuntimeError("Cannot read FPS.")
    n, d = map(float, r.split("/"))
    return n / d


def build_filter_complex_for_frame_trim(
    trim: TrimWindow,
    fps: float,
    height: int,
    keep_audio: bool,
    crop_filter: str | None,
) -> tuple[str, str, str | None]:
    assert trim.mode == "frames"
    fstart, fend = trim.frame_range()
    start_s, end_s = trim.seconds_range(fps=fps)
    vend = fend if fend is not None else 999999999
    v_parts = [
        f"select='between(n\\,{fstart}\\,{vend})'",
        "setpts=PTS-STARTPTS",
    ]
    if crop_filter:
        v_parts.append(crop_filter)
    v_parts.append(f"scale=-2:{height}")
    vchain = f"[0:v]{','.join(v_parts)}[vout]"
    if not keep_audio:
        return vchain, "[vout]", None
    if end_s is None:
        achain = f"[0:a]atrim=start={start_s},asetpts=PTS-STARTPTS[aout]"
    else:
        achain = f"[0:a]atrim=start={start_s}:end={end_s},asetpts=PTS-STARTPTS[aout]"
    return f"{vchain};{achain}", "[vout]", "[aout]"


class BaseCompressor:
    def __init__(self, args: argparse.Namespace):
        self.args = args
        self.input: Path = args.input
        self.output: Path = args.output or self.default_output()
        self.fps: float | None = None
        self.crop_filter = crop_filter_from_args(args)

    def default_output(self) -> Path:
        raise NotImplementedError

    def base_cmd(self) -> list[str]:
        return ["ffmpeg", "-hide_banner", "-loglevel", "error", "-stats", "-y"]

    def run(self) -> None:
        cmd = self.build_cmd()
        subprocess.check_call(cmd)

    def trim_window(self) -> TrimWindow:
        mode = TrimWindow.mode_from_args(self.args)
        if mode == "frames":
            self.fps = probe_fps(self.input)
            return TrimWindow.from_args(self.args, fps=self.fps)
        return TrimWindow.from_args(self.args)

    def build_cmd(self) -> list[str]:
        raise NotImplementedError("not implemented")


class GifCompressor(BaseCompressor):
    def default_output(self) -> Path:
        return self.input.with_name(self.input.stem + "-compressed.gif")

    def build_cmd(self) -> list[str]:
        cmd = self.base_cmd()

        crop_prefix = f"{self.crop_filter}," if self.crop_filter else ""
        palette_vf = "".join(
            [
                f"{crop_prefix}scale=-2:{self.args.height}:flags=lanczos,",
                "split[s0][s1];",
                "[s0]palettegen=stats_mode=diff[p];",
                "[s1][p]paletteuse=new=1",
            ]
        )

        trim = self.trim_window()
        if trim.mode == "frames":
            assert self.fps is not None
            fc, v_label, _ = build_filter_complex_for_frame_trim(
                trim,
                self.fps,
                self.args.height,
                keep_audio=False,
                crop_filter=self.crop_filter,
            )
            chain = (
                f"{fc};{v_label}split[v1][v2];"
                f"[v1]palettegen=stats_mode=diff[p];[v2][p]paletteuse=new=1"
            )
            cmd += ["-i", str(self.input)]
            cmd += ["-filter_complex", chain]
        else:
            cmd += trim.ffmpeg_timestamp_flags()
            cmd += ["-i", str(self.input)]
            cmd += ["-vf", palette_vf]

        cmd += ["-loop", "0"]
        cmd += [str(self.output)]
        return cmd


class VideoCompressor(BaseCompressor):
    def default_output(self) -> Path:
        return self.input.with_name(self.input.stem + "-compressed.mp4")

    def video_codec_flags(self) -> list[str]:
        return [
            "-c:v",
            "libx264",
            "-b:v",
            self.args.quality,
            "-preset",
            self.args.preset,
        ]

    def audio_codec_flags(self) -> list[str]:
        return (
            ["-an"]
            if self.args.no_audio
            else ["-c:a", "aac", "-b:a", "128k", "-ar", "44100"]
        )

    def build_cmd(self) -> list[str]:
        cmd = self.base_cmd()
        cmd += ["-i", str(self.input)]

        trim = self.trim_window()
        if trim.mode == "frames":
            assert self.fps is not None
            fc, v_label, a_label = build_filter_complex_for_frame_trim(
                trim,
                self.fps,
                self.args.height,
                keep_audio=not self.args.no_audio,
                crop_filter=self.crop_filter,
            )
            cmd += ["-filter_complex", fc]
            cmd += ["-map", v_label]
            if a_label:
                cmd += ["-map", a_label]
        else:
            cmd += trim.ffmpeg_timestamp_flags()
            cmd += [
                "-vf",
                build_video_filter(self.args.height, self.crop_filter),
            ]

        cmd += self.video_codec_flags()
        cmd += self.audio_codec_flags()
        cmd += ["-movflags", "+faststart", str(self.output)]
        return cmd


def main() -> None:
    args = parse_args()
    compressor = GifCompressor(args) if args.gif else VideoCompressor(args)
    compressor.run()


if __name__ == "__main__":
    main()
